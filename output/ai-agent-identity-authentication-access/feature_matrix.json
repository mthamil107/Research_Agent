  "feature_descriptions": {
    "agent_identity_lifecycle": "Create, manage, suspend, revoke agent identities through their full lifecycle",
    "agent_registration_discovery": "Discover and register AI agents across the environment automatically",
    "oauth_mcp_auth": "OAuth 2.1 / MCP protocol authentication for agent-to-service communication",
    "delegated_access": "Agents act on behalf of users with scoped, delegated permissions",
    "fine_grained_authz": "ABAC/ReBAC/FGA beyond basic RBAC for complex agent permission models",
    "secrets_management": "Store, encrypt, and manage secrets centrally",
    "secret_rotation": "Automated credential rotation on schedule or event",
    "secretless_access": "Eliminate static secrets via ephemeral credentials or workload identity",
    "nhi_discovery_inventory": "Discover and inventory all non-human identities including agents",
    "behavior_monitoring": "Runtime monitoring of agent actions for anomalies and policy violations",
    "audit_trails": "Comprehensive logging of all agent access and actions",
    "policy_as_code": "Define and version access policies as code (OPA, Polar, YAML, etc.)",
    "third_party_oauth": "Managed OAuth flows for agents connecting to third-party SaaS",
    "mfa_for_agents": "Multi-factor authentication support for agent access",
    "zero_trust_enforcement": "Never trust, always verify for every agent action",
    "spiffe_workload_id": "SPIFFE/SPIRE-based cryptographic workload identity",
    "just_in_time_access": "Temporary, on-demand access grants that auto-expire",
    "access_reviews_governance": "Periodic access reviews and compliance reporting",
    "multi_cloud_support": "Works across AWS, Azure, GCP, and on-prem environments",
    "open_source": "Open-source core or community edition available"
  },

  "feature_descriptions": {
    "tracing_observability": "Ability to trace LLM calls, agent steps, and tool usage end-to-end",
    "llm_as_judge": "Uses an LLM to evaluate outputs of another LLM for quality/relevance",
    "human_annotation": "Supports human-in-the-loop review and labeling of outputs",
    "hallucination_detection": "Specific metrics or models for detecting fabricated information",
    "rag_evaluation": "Specialized metrics for RAG pipelines (faithfulness, context relevance, etc.)",
    "agent_workflow_tracing": "Traces multi-step agent reasoning, tool calls, and decision paths",
    "multi_agent_support": "Can test and monitor systems with multiple cooperating agents",
    "red_teaming_security": "Adversarial testing, prompt injection detection, jailbreak testing",
    "ci_cd_integration": "Integrates into CI/CD pipelines for automated eval on every deploy",
    "prompt_management": "Version control, A/B testing, and management of prompts",
    "cost_tracking": "Tracks token usage and associated costs across providers",
    "latency_monitoring": "Monitors response times and identifies performance bottlenecks",
    "dataset_management": "Create, manage, and version evaluation datasets",
    "ab_testing": "Compare two or more model/prompt variants systematically",
    "guardrails_realtime": "Real-time content filtering and safety checks on live traffic",
    "open_source": "Core product is open-source",
    "self_hostable": "Can be deployed on-premise or in private cloud",
    "multi_model_support": "Works with multiple LLM providers (OpenAI, Anthropic, Google, etc.)",
    "visual_reports_dashboards": "Graphical dashboards and reports for evaluation results",
    "session_replay": "Replay agent sessions step-by-step for debugging",
    "user_persona_simulation": "Simulate different user types/personas to test agent behavior",
    "regression_detection": "Detect when model/prompt changes cause quality degradation",
    "compliance_audit": "Audit trails and compliance reporting for regulated industries",
    "sdk_cli_first": "Primary interface is SDK or CLI rather than UI",
    "no_code_low_code": "Accessible to non-technical users through UI-based workflows"
  },

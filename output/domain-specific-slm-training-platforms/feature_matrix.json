{
  "metadata": {
    "domain": "Domain-specific SLM training platforms",
    "scan_date": "2026-03-25",
    "feature_categories": [
      "Data Pipeline",
      "Training Methods",
      "Model Support",
      "Deployment",
      "Domain Adaptation",
      "Usability",
      "Enterprise Features",
      "Evaluation"
    ]
  },
  "feature_definitions": {
    "no_code_ui": "Visual/no-code interface for fine-tuning",
    "data_pipeline": "Built-in data preparation, cleaning, formatting tools",
    "domain_data_ingestion": "Ability to ingest domain-specific raw files (PDFs, docs, CSVs)",
    "synthetic_data_generation": "Tools to generate synthetic training data",
    "lora_qlora": "Support for LoRA and QLoRA parameter-efficient fine-tuning",
    "full_fine_tuning": "Support for full model weight fine-tuning",
    "rlhf_dpo": "RLHF, DPO, or other preference-based optimization",
    "grpo": "Group Relative Policy Optimization (DeepSeek-R1 style)",
    "continued_pretraining": "Domain-adaptive continued pretraining on raw corpus",
    "multi_gpu": "Multi-GPU distributed training support",
    "multi_node": "Multi-node distributed training support",
    "consumer_gpu": "Can run on consumer GPUs (12-24GB VRAM)",
    "model_breadth": "Number of base models supported",
    "multimodal": "Fine-tuning of vision-language or multimodal models",
    "one_click_deploy": "One-click or easy deployment after training",
    "edge_export": "Export to edge formats (GGUF, ONNX, TensorRT)",
    "api_serving": "OpenAI-compatible or standard API serving",
    "domain_evaluation": "Domain-specific evaluation metrics and benchmarks",
    "llm_as_judge": "LLM-as-a-Judge evaluation capability",
    "auto_hyperparameter": "Automatic hyperparameter tuning",
    "experiment_tracking": "Experiment tracking and comparison",
    "on_premise": "On-premise / air-gapped deployment option",
    "data_privacy": "Strong data privacy (SOC2, HIPAA, encryption)",
    "cost_optimization": "Built-in cost monitoring and optimization"
  },

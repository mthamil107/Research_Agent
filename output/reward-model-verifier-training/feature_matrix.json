  "feature_descriptions": {
    "prm_training": "Native support for training Process Reward Models with step-level supervision",
    "orm_training": "Native support for training Outcome Reward Models with final-answer labels",
    "genrm_training": "Support for generative verifier training (next-token prediction based verification)",
    "custom_domain_verifier": "Ability to train verifiers for custom domains beyond math/code",
    "math_verifier": "Built-in support or recipes for math reasoning verification",
    "code_verifier": "Built-in support or recipes for code reasoning verification",
    "multi_domain_verifier": "Training verifiers that work across multiple domains simultaneously",
    "synthetic_data_generation": "Tools for generating synthetic training data for reward models",
    "automated_step_labeling": "Automatic labeling of reasoning steps without human annotation",
    "grpo_support": "Group Relative Policy Optimization support",
    "ppo_support": "Proximal Policy Optimization support",
    "dpo_support": "Direct Preference Optimization support",
    "slm_optimized": "Specifically optimized for small language models (<10B params)",
    "consumer_gpu_friendly": "Can run on consumer GPUs (24GB VRAM or less)",
    "distributed_multi_node": "Supports multi-node distributed training",
    "vllm_integration": "Integration with vLLM for fast inference/rollouts",
    "tree_search_inference": "MCTS or beam search with reward model guidance at inference",
    "rlvr_verifiable_rewards": "Support for reinforcement learning with verifiable/programmatic rewards",
    "online_rl": "Support for online reinforcement learning with live rollouts",
    "data_annotation_ui": "User interface for human preference/step annotation",
    "pretrained_rm_available": "Comes with or links to pretrained reward models",
    "lora_qlora_support": "Support for parameter-efficient fine-tuning"
  },

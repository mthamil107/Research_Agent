    "step_level_verification": "Can verify individual reasoning steps, not just final answers",
    "adversarial_robustness": "Tests model reasoning under adversarial/perturbed inputs",
    "efficiency_metrics": "Measures computational cost, latency, memory alongside accuracy",
    "dynamic_generation": "Generates new evaluation instances programmatically",
    "leaderboard": "Public leaderboard for model comparison",
    "ci_cd_integration": "Can be integrated into CI/CD pipelines for automated evaluation",
    "multi_model_backend": "Supports multiple model serving backends (vLLM, sglang, HF, etc.)",
    "process_reward_model": "Includes or evaluates process reward models for reasoning",
    "chain_of_thought_eval": "Evaluates quality of chain-of-thought reasoning traces",
    "custom_task_creation": "Users can define custom evaluation tasks",
    "sustainability_metrics": "Measures energy consumption and environmental impact",
    "edge_deployment_eval": "Evaluates models in edge/resource-constrained settings",
    "quantization_aware_eval": "Evaluates reasoning quality across quantization levels",
    "multi_language_support": "Evaluates reasoning in multiple natural languages",
    "api_commercial_support": "Commercial API or enterprise support available",
    "real_time_monitoring": "Continuous evaluation/monitoring in production"
  },

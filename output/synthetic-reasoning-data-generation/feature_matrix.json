  "feature_descriptions": {
    "cot_trace_generation": "Can generate chain-of-thought reasoning traces as training data",
    "multi_step_reasoning": "Supports multi-step / multi-hop reasoning data generation",
    "tool_use_data": "Can generate tool/API calling training data with reasoning",
    "math_reasoning_data": "Specialized in mathematical reasoning dataset creation",
    "code_reasoning_data": "Specialized in code reasoning / debugging dataset creation",
    "seedless_generation": "Can generate data without requiring seed examples or prompts",
    "quality_filtering": "Built-in quality filtering or rejection sampling for generated data",
    "reward_model_scoring": "Includes or integrates reward models for scoring outputs",
    "rl_training_integration": "Direct integration with RL training (RLHF/RLAIF/RLVR)",
    "distillation_support": "Supports knowledge distillation from larger to smaller models",
    "multi_llm_provider": "Works with multiple LLM providers (OpenAI, Anthropic, local, etc.)",
    "pipeline_orchestration": "Provides pipeline/workflow orchestration for multi-stage generation",
    "scalable_parallel_gen": "Supports parallel/distributed generation at scale",
    "human_in_the_loop": "Supports human review/annotation in the generation loop",
    "domain_customization": "Easily customizable for specific domains (legal, medical, finance)",
    "privacy_preserving": "Includes differential privacy or PII protection mechanisms",
    "open_source": "Fully open source with permissive license",
    "ui_interface": "Provides a graphical user interface for non-technical users",
    "verifiable_reasoning": "Generates reasoning that can be formally verified (math proofs, code exec)",
    "difficulty_control": "Allows control over difficulty/complexity of generated reasoning"
  },
